{
  "expo": {
    "name": "かしかり.me",
    "slug": "kashikari-me-beta",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "kashikarime",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8F2"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.toshimaru.kashikarime",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFF8F2"
      },
      "package": "com.toshimaru.kashikarime",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "グループメンバーを招待するためにカメラを使用します。"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "970c9875-04eb-4c45-b3e2-89276b8c80a7"
      }
    },
    "owner": "toshimaru"
  }
}
